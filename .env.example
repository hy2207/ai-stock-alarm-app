# Prisma
DATABASE_URL="file:./dev.db"
POSTGRES_URL="postgresql://user:password@host:5432/db"

# Auth
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# LLM
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="models/gemini-2.0-flash-001"

# Market data
FINNHUB_API_KEY="your-finnhub-api-key"

# Analytics
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Push
ONESIGNAL_APP_ID="your-onesignal-app-id"
NEXT_PUBLIC_ONESIGNAL_APP_ID="your-onesignal-app-id"
ONESIGNAL_REST_API_KEY="your-onesignal-rest-api-key"

# Cron
CRON_SECRET="your-cron-secret"

# Admin health snapshots (ISO timestamp strings, no secrets)
LAST_YAHOO_FINANCE_SYNC_AT=""
LAST_FINNHUB_SYNC_AT=""
MARKET_DATA_NULL_RATE="0"
