# Prisma / Supabase
# DATABASE_URL  → Transaction mode (pgBouncer port 6543) — Prisma Client at runtime
# POSTGRES_URL  → Session mode (direct port 5432) — Prisma migrate / db push
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
POSTGRES_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# Auth
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# LLM
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.0-flash-001"

# Market data
FINNHUB_API_KEY="your-finnhub-api-key"

# Analytics
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Push
NEXT_PUBLIC_ONESIGNAL_APP_ID="your-onesignal-app-id"
ONESIGNAL_REST_API_KEY="your-onesignal-rest-api-key"

# Cron
CRON_SECRET="your-cron-secret"

# Admin health snapshots (ISO timestamp strings, no secrets)
LAST_YAHOO_FINANCE_SYNC_AT=""
LAST_FINNHUB_SYNC_AT=""
MARKET_DATA_NULL_RATE="0"
